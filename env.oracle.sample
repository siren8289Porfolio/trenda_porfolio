# Oracle Cloud 배포용 샘플 환경 변수
# 실제 비밀번호/접속 문자열은 커밋하지 말고 Oracle Cloud VM 또는 Container Instance 환경 변수에 등록하세요.

# Backend
BACKEND_PORT=8080
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -Djava.security.egd=file:/dev/./urandom

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://YOUR_ORACLE_PUBLIC_IP:8080
